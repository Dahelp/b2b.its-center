APP_ENV=production
APP_URL=https://b2b.its-center.ru

# Shared database with its-center.ru
DB_CONFIG_FILE=
DB_DSN=mysql:host=127.0.0.1;dbname=its_center;charset=utf8mb4
DB_USER=
DB_PASSWORD=

# 1C callback authentication; send it in the X-1C-Token header.
API_1C_CALLBACK_TOKEN=

# Outgoing 1C HTTP services
API_1C_HOST=
API_1C_BASE=
API_1C_USER=
API_1C_PASSWORD=
API_1C_CACHE_TTL=30
API_1C_STALE_TTL=86400
